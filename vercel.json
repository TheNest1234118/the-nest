{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
"crons": [
  {
    "path": "/api/daily-reminder",
    "schedule": "*/15 * * * *"
  }
]
}